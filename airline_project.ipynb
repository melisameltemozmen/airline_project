      "source": [
        "# MCDM AŞAMASI:\n",
        "\n",
        "#AHP based TOPSIS\n",
        "\n",
        "# ADIM 1: AHP İLE AĞIRLIK BELİRLEME\n",
        "\n",
        "# AHP"de \"İkili Karşılaştırma Matrisi\" (Pairwise Comparison Matrix) kurarız.\n",
        "# Saaty Ölçeği (1-9):\n",
        "# 1: Eşit, 3: Biraz daha önemli, 5: Çok önemli, 1/3: Daha az önemli vb.\n",
        "\n",
        "# Kriter Sıramız: [Accuracy, Precision, Recall, F1 Score, AUC]\n",
        "# Mantığımız (Literatüre Uygun):\n",
        "# - F1 en önemlisi (Çünkü dengeyi kurar).\n",
        "# - AUC ikinci en önemli (Ayırt edicilik).\n",
        "# - Accuracy en az önemli (Dengesiz veri riski).\n",
        "\n",
        "# Matrisi kuralım (Satırlar ve Sütunlar aynı sırada)\n",
        "ahp_matrix = np.array([\n",
        "    # Acc   Prec   Rec    F1     AUC\n",
        "    [1.00,  0.50,  0.50,  0.20,  0.33], # Accuracy (Hepsinden daha az önemli)\n",
        "    [2.00,  1.00,  1.00,  0.33,  0.50], # Precision (Accuracy"den önemli, F1"den az)\n",
        "    [2.00,  1.00,  1.00,  0.33,  0.50], # Recall (Precision ile eşit tuttuk)\n",
        "    [5.00,  3.00,  3.00,  1.00,  2.00], # F1 Score (HEPSİNDEN ÖNEMLİ - Kral)\n",
        "    [3.00,  2.00,  2.00,  0.50,  1.00]  # AUC (F1"in yardımcısı, diğerlerinden üstün)\n",
        "])\n",
        "\n",
        "# AHP Ağırlık Hesabı (Sütun Normalizasyonu Yöntemi)\n",
        "column_sums = ahp_matrix.sum(axis=0)\n",
        "normalized_ahp_matrix = ahp_matrix / column_sums\n",
        "ahp_weights = normalized_ahp_matrix.mean(axis=1)\n",
        "\n",
        "print(\"\\n--- AHP İLE HESAPLANAN BİLİMSEL AĞIRLIKLAR ---\")\n",
        "criteria_names = [\"Accuracy\", \"Precision\", \"Recall\", \"F1 Score\", \"AUC\"]\n",
        "for name, weight in zip(criteria_names, ahp_weights):\n",
        "    print(f\"{name}: %{weight*100:.2f}\")\n",
        "\n",
        "# ADIM 2: BU AĞIRLIKLARLA TOPSIS HESAPLAMA\n",
        "\n",
        "df_ahp_topsis = df_results.set_index("Model").copy()\n",
        "matrix = df_ahp_topsis.values\n",
        "\n",
        "# Vektör Normalizasyonu\n",
        "divisors = np.sqrt((matrix**2).sum(axis=0))\n",
        "norm_matrix = matrix / divisors\n",
        "\n",
        "# AHP Ağırlıklarıyla Çarpma (Weighted Matrix)\n",
        "# Burada "ahp_weights" değişkenini kullanıyoruz\n",
        "weighted_matrix = norm_matrix * ahp_weights\n",
        "\n",
        "# İdeal Çözümler\n",
        "ideal_best = weighted_matrix.max(axis=0)\n",
        "ideal_worst = weighted_matrix.min(axis=0)\n",
        "\n",
        "# Mesafeler\n",
        "dist_best = np.sqrt(((weighted_matrix - ideal_best)**2).sum(axis=1))\n",
        "dist_worst = np.sqrt(((weighted_matrix - ideal_worst)**2).sum(axis=1))\n",
        "\n",
        "# Skorlar\n",
        "ahp_topsis_scores = dist_worst / (dist_best + dist_worst)\n",
        "\n",
        "#ADIM 3: KARŞILAŞTIRMA (EŞİT AĞIRLIK vs AHP AĞIRLIKLI) ---\n",
        "\n",
        "df_final_comparison = pd.DataFrame({\n",
        "    "Model": df_ahp_topsis.index,\n",
        "    "AHP-TOPSIS Score": ahp_topsis_scores\n",
        "}).set_index("Model")\n",
        "\n",
        "# Sıralama\n",
        "df_final_comparison = df_final_comparison.sort_values(by="AHP-TOPSIS Score", ascending=False)\n",
        "\n",
        "print(\"\\n--- AHP DESTEKLİ TOPSIS SONUCU ---\")\n",
        "print(df_final_comparison)\n",
        "\n",
        "best_model = df_final_comparison.index[0]\n",
        "print(f\"\\n LİTERATÜRE EN UYGUN SEÇİLEN MODEL: {best_model}\")\n",
        "\n",
        "\n"
      ]
    },
