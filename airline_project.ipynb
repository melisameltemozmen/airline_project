        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.preprocessing import LabelEncoder , StandardScaler\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.impute import SimpleImputer\n",
        "\n",
        "\n",
        "df = pd.read_csv("airlineproject.csv", sep=";")\n",
        "print(\"Ham veri yüklendi. Boyut:\", df.shape)\n",
        "\n",
        "#GEREKSİZ SÜTUNLARI SİLME\n",
        "# "Unnamed: 0" ve "id" sütunları model için gereksiz.\n",
        "# errors="ignore" ekledik ki eğer bu sütunlar yoksa hata verip durmasın.\n",
        "df.drop(["Unnamed: 0", "id"], axis=1, inplace=True, errors="ignore")\n",
        "\n",
        "#EKSİK VERİLERİ DOLDURMA\n",
        "# Sadece "Arrival Delay in Minutes" sütununda boşluklar olabiliyor.\n",
        "# Boş yerlere median imputation-sağa çarpık olduğu için median seçtik.\n",
        "df["Arrival Delay in Minutes"] = df["Arrival Delay in Minutes"].fillna(df["Arrival Delay in Minutes"].median())\n",
        "\n",
        "#KATEGORİK VERİLERİ SAYIYA ÇEVİRME (ENCODING)\n",
        "# Modelin anlaması için "Male" -> 1, "Female" -> 0 gibi dönüşümler yapıyoruz.\n",
        "le = LabelEncoder()\n",
        "\n",
        "# Tipi "object" (yazı) olan sütunları bulup döngüyle çeviriyoruz\n",
        "object_cols = df.select_dtypes(include=["object"]).columns\n",
        "\n",
        "print(\"\\nŞu sütunlar sayıya çevriliyor:\")\n",
        "for col in object_cols:\n",
        "    df[col] = le.fit_transform(df[col])\n",
        "    print(f\"- {col}\")\n",
        "\n",
        "#TEMİZLENMİŞ VERİYİ KAYDETME\n",
        "df.to_csv("cleaned_data.csv", index=False)\n",
        "\n",
        "print(\"\\nİŞLEM TAMAM!\")\n",
        "print(\"Temizlenmiş veri "cleaned_data.csv" olarak kaydedildi.\")\n",
        "print(\"Verinin son hali (ilk 5 satır):\")\n",
        "print(df.head())"
      ]
    },
