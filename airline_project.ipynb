      "source": [
        "#Görselleştirmeler\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "plt.rcParams["figure.figsize"] = (12, 8)\n",
        "plt.rcParams["font.size"] = 12\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# GRAFİK 1: TÜM MODELLERİN PERFORMANS METRİKLERİ (Çoklu Bar)\n",
        "# ---------------------------------------------------------\n",
        "print(\"Grafik 1: Model Performans Karşılaştırması oluşturuluyor...\")\n",
        "# Veriyi görselleştirme için uygun formata (long format) çevirelim\n",
        "df_melted = df_results.reset_index().melt(id_vars="Model", var_name="Metric", value_name="Score")\n",
        "\n",
        "plt.figure(figsize=(14, 7))\n",
        "# \"husl\" renk paleti ile canlı renkler kullanalım\n",
        "ax1 = sns.barplot(data=df_melted, x="Model", y="Score", hue="Metric", palette="husl")\n",
        "\n",
        "# Başlık ve Eksenler\n",
        "plt.title("Makine Öğrenmesi Modellerinin Performans Karşılaştırması", fontsize=16, fontweight="bold")\n",
        "plt.ylabel("Skor (0-1 Arası)", fontsize=14)\n",
        "plt.xlabel("Modeller", fontsize=14)\n",
        "plt.ylim(0.8, 1.0) # Skorlar yüksek olduğu için alt sınırı 0.8 yapalım, farklar netleşsin\n",
        "plt.legend(title="Metrikler", bbox_to_anchor=(1.05, 1), loc="upper left")\n",
        "plt.xticks(rotation=15) # Model isimleri uzunsa çapraz yazsın\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# GRAFİK 2: AHP KRİTER AĞIRLIKLARI (Pasta Grafiği)\n",
        "# ---------------------------------------------------------\n",
        "print(\"Grafik 2: AHP Ağırlıkları Pasta Grafiği oluşturuluyor...\")\n",
        "# AHP"den gelen ağırlıkları kullanalım\n",
        "criteria_labels = [\"Accuracy\", \"Precision\", \"Recall\", \"F1 Score\", \"AUC\"]\n",
        "# ahp_weights değişkeni önceki kod bloğundan geliyor\n",
        "colors = sns.color_palette("pastel")[0:5]\n",
        "\n",
        "plt.figure(figsize=(8, 8))\n",
        "# F1 Score en önemli olduğu için onu "explode" ile biraz dışarı çıkaralım\n",
        "explode = (0, 0, 0, 0.1, 0)\n",
        "plt.pie(ahp_weights, labels=criteria_labels, colors=colors, autopct="%1.1f%%", startangle=140, explode=explode, shadow=True)\n",
        "plt.title("AHP Yöntemi ile Belirlenen Kriter Ağırlıkları", fontsize=16, fontweight="bold")\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# GRAFİK 3: NİHAİ AHP-TOPSIS SIRALAMASI (Yatay Bar)\n",
        "# ---------------------------------------------------------\n",
        "print(\"Grafik 3: Nihai TOPSIS Sıralaması oluşturuluyor...\")\n",
        "# df_final_comparison tablosunu kullanıyoruz\n",
        "plt.figure(figsize=(10, 6))\n",
        "# Skora göre renklendirme yapalım (Blues paleti: koyu mavi en iyi)\n",
        "ax3 = sns.barplot(x=df_final_comparison["AHP-TOPSIS Score"], y=df_final_comparison.index, palette="Blues_r")\n",
        "\n",
        "# Başlık ve Eksenler\n",
        "plt.title("AHP Destekli TOPSIS Yöntemine Göre Nihai Model Sıralaması", fontsize=16, fontweight="bold")\n",
        "plt.xlabel("TOPSIS Skoru (İdeal Çözüme Yakınlık)", fontsize=14)\n",
        "plt.ylabel("Modeller", fontsize=14)\n",
        "plt.xlim(0, 1.1) # Barların ucuna skorları yazmak için biraz boşluk bırakalım\n",
        "\n",
        "# Barların ucuna skorları yazdıralım\n",
        "for i, v in enumerate(df_final_comparison["AHP-TOPSIS Score"]):\n",
        "    ax3.text(v + 0.02, i, f\"{v:.4f}\", color="black", va="center", fontweight="bold")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# GRAFİK 4: KAZANAN MODELİN (XGBOOST) KARIŞIKLIK MATRİSİ\n",
        "# ---------------------------------------------------------\n",
        "print(f\"Grafik 4: {best_model} için Karışıklık Matrisi oluşturuluyor...\")\n",
        "# Kazanan modeli tekrar eğitelim veya models sözlüğünden çekelim\n",
        "best_model_instance = models[best_model]\n",
        "# (Not: best_model değişkeni önceki kodda "XGBoost" olarak belirlenmişti)\n",
        "\n",
        "# Test seti üzerinde tahminleri alalım\n",
        "y_pred_best = best_model_instance.predict(X_test_scaled)\n",
        "\n",
        "# Karışıklık Matrisini Hesapla\n",
        "cm = confusion_matrix(y_test, y_pred_best)\n",
        "\n",
        "# Görselleştir\n",
        "plt.figure(figsize=(8, 6))\n",
        "# Sınıf etiketleri: 0 (Memnun Değil), 1 (Memnun) - Veri setine göre değişebilir\n",
        "# Etiketleri projenize göre güncelleyebilirsiniz: display_labels=["Nötr/Mutsuz", "Mutlu"]\n",
        "disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=["Sınıf 0", "Sınıf 1"])\n",
        "# Koyu mavi (Blues) renk haritası kullanalım, değerler içinde tamsayı (d) olarak yazsın\n",
        "disp.plot(cmap="Blues", values_format="d", ax=plt.gca())\n",
        "plt.title(f"Karışıklık Matrisi (Confusion Matrix) - {best_model}", fontsize=16, fontweight="bold")\n",
        "plt.grid(False) # Seaborn grid"i matrisi bozmasın diye kapatalım\n",
        "plt.show()\n",
        "\n",
        "# ---------------------------------------------------------\n",
        "# GRAFİK 5: EN İYİ MODELİN (XGBOOST) ÖZNİTELİK ÖNEMİ (FEATURE IMPORTANCE)\n",
        "# ---------------------------------------------------------\n",
        "print(f\"Grafik 5: {best_model} için Öznitelik Önemi grafiği oluşturuluyor...\")\n",
        "\n",
        "# 1. En iyi modelin eğitilmiş halini alalım\n",
        "best_xgb_model = models[best_model]\n",
        "\n",
        "# 2. Önem derecelerini ve sütun isimlerini alalım\n",
        "feature_importances = best_xgb_model.feature_importances_\n",
        "# X verisi encode edilmiş son haliyle duruyor olmalı\n",
        "feature_names = X.columns\n",
        "\n",
        "# 3. Pandas DataFrame"e çevirip sıralayalım\n",
        "df_importance = pd.DataFrame({\n",
        "    "Feature": feature_names,\n",
        "    "Importance": feature_importances\n",
        "}).sort_values(by="Importance", ascending=False)\n",
        "\n",
        "# 4. Görselleştirme (İlk 10 Özellik)\n",
        "plt.figure(figsize=(12, 8))\n",
        "# Not: "hue" parametresi uyarısını düzeltmek için "hue" ekleyip legend=False yaptık.\n",
        "sns.barplot(x="Importance", y="Feature", hue="Feature", data=df_importance.head(10), palette="viridis", legend=False)\n",
        "\n",
        "# Başlık ve Eksenler\n",
        "plt.title(f"Müşteri Memnuniyetini En Çok Etkileyen 10 Faktör ({best_model})", fontsize=16, fontweight="bold")\n",
        "plt.xlabel("Önem Düzeyi (Importance Score)", fontsize=14)\n",
        "plt.ylabel("Hizmet / Faktör", fontsize=14)\n",
        "\n",
        "for i, v in enumerate(df_importance["Importance"].head(10)):\n",
        "    plt.text(v + 0.005, i, f\"{v:.4f}\", color="black", va="center')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "\n"
        
