        "# XGBOOST FEATURE IMPORTANCE\n",
        "\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "#En iyi modelin (XGBoost) eğitilmiş halini alıyoruz\n",
        "best_xgb_model = models[\"XGBoost\"] # Veya best_model_instance\n",
        "feature_importances = best_xgb_model.feature_importances_\n",
        "\n",
        "#Sütun isimlerini alıyoruz (One-Hot Encoding sonrası sütun isimleri)\n",
        "# X_train bir DataFrame değilse (numpy array ise) sütun isimlerini baştan almalıyız\n",
        "# X değişkeni encode edilmiş haliyle duruyorsa:\n",
        "feature_names = X.columns\n",
        "\n",
        "#Bir DataFrame oluşturup sıralayalım\n",
        "df_importance = pd.DataFrame({\n",
        "    "Feature": feature_names,\n",
        "    "Importance": feature_importances\n",
        "}).sort_values(by="Importance", ascending=False)\n",
        "\n",
        "print(\"\\n--- XGBOOST MODELİNE GÖRE EN KRİTİK 5 FAKTÖR ---\")\n",
        "print(df_importance.head(5))\n",
        "\n",
        "#Görselleştirme (İlk 10 Özellik)\n",
        "plt.figure(figsize=(12, 8))\n",
        "sns.barplot(x="Importance", y="Feature", hue="Feature", data=df_importance.head(10), palette="viridis", legend=False)\n",
        "plt.title("Müşteri Memnuniyetini En Çok Etkileyen 10 Faktör (XGBoost)", fontsize=16, fontweight="bold")\n",
        "plt.xlabel("Önem Düzeyi (Importance Score)", fontsize=14)\n",
        "plt.ylabel("Hizmet / Faktör", fontsize=14)\n",
        "plt.show()\n"
      ]
